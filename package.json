		"svelte": "^4.2.19",
		"svelte-check": "^4.0.4",
		"tailwindcss": "^3.4.13",
		"tslib": "^2.7.0",
		"typescript": "^5.6.2",
		"typescript-eslint": "^8.8.0",
		"vite": "^5.4.8"
	},
	"type": "module",
	"dependencies": {
		"@vercel/postgres": "^0.10.0",
		"dotenv": "^16.4.5",
		"drizzle-orm": "^0.33.0",
		"mysql2": "^3.11.3"
	}
