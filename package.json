		"@oslojs/crypto": "^1.0.1",
		"@oslojs/encoding": "^1.1.0",
		"dotenv": "^16.4.5",
		"drizzle-orm": "^0.33.0",
		"firebase": "^11.2.0",
		"firebase-admin": "^13.4.0",
		"jquery": "^3.7.1",
		"marked": "^17.0.0",
		"minisearch": "^7.1.1",
		"mysql2": "^3.11.3"
	}
